{
    "manifest_version": 3,
    "name": "TabStash",
    "version": "1.2.1",
    "author": "Vinay Tiparadi",
    "description": "Archive your open tabs and restore them later instantly.",
    "browser_specific_settings": {
        "gecko": {
            "id": "tabstash@vinaytiparadi.com",
            "strict_min_version": "128.0"
        }
    },
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "icon-16.png",
            "32": "icon-32.png",
            "48": "icon-48.png",
            "128": "icon-128.png"
        }
    },
    "icons": {
        "16": "icon-16.png",
        "32": "icon-32.png",
        "48": "icon-48.png",
        "128": "icon-128.png"
    },
    "background": {
        "scripts": ["src/background.ts"],
        "type": "module"
    },
    "permissions": [
        "tabs",
        "storage"
    ]
}
